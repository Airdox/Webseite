{
  "name": "airdox-web",
  "private": true,
  "version": "0.1.3",
  "main": "desktop/main/index.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:site": "vite build",
    "desktop:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/desktop-dev.ps1",
    "desktop:start": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Remove-Item Env:ELECTRON_RUN_AS_NODE -ErrorAction SilentlyContinue; electron .\"",
    "desktop:dist": "npm version patch --no-git-tag-version && npm run build && electron-builder --win portable",
    "desktop:dist:setup": "npm version patch --no-git-tag-version && npm run build && electron-builder --win nsis",
    "desktop:dist:minor": "npm version minor --no-git-tag-version && npm run build && electron-builder --win portable",
    "desktop:dist:major": "npm version major --no-git-tag-version && npm run build && electron-builder --win portable",
    "desktop:dist:setup:minor": "npm version minor --no-git-tag-version && npm run build && electron-builder --win nsis",
    "desktop:dist:setup:major": "npm version major --no-git-tag-version && npm run build && electron-builder --win nsis",
    "desktop:installer": "electron-builder --prepackaged release/win-unpacked --win nsis",
    "desktop:test": "vitest run src/desktop/__tests__",
    "desktop:test:logic": "vitest run src/desktop/lib/__tests__ src/desktop/__tests__",
    "desktop:test:e2e": "playwright test e2e/desktop-flightdeck.spec.js e2e/flightdeck-quality.spec.js e2e/flightdeck-assistant.spec.js",
    "desktop:test:proof": "node scratch/capture-analytics-filter-proof.mjs",
    "desktop:test:all": "npm run desktop:test:logic && npm run desktop:test:e2e",
    "tracklist:auto": "node scripts/generate-mixcloud-tracklists.mjs",
    "tracklist:watch": "node scripts/generate-mixcloud-tracklists.mjs --watch --mode cue",
    "tracklist:normalize": "node scripts/normalize-tracklist.mjs",
    "brand:epk": "node scripts/build-airdox-epk.mjs",
    "brand:epk:pdf": "node scripts/build-airdox-epk.mjs --pdf",
    "manni:reels:generate": "node scripts/manni-reel-factory.mjs",
    "social:auto": "node scripts/social-auto-publisher.mjs",
    "social:auto:dry": "node scripts/social-auto-publisher.mjs --skip-render",
    "social:run": "npm run social:auto && npm run social:youtube:render:test && npm run social:youtube:publish -- --privacy=unlisted",
    "social:youtube:oauth:init": "node scripts/social-youtube-oauth-init.mjs",
    "social:youtube:publish": "node scripts/social-youtube-publish.mjs",
    "social:youtube:publish:short": "node scripts/social-youtube-publish.mjs --mode=short",
    "social:youtube:dry": "node scripts/social-youtube-publish.mjs --dry-run",
    "social:youtube:render": "node scripts/social-youtube-publish.mjs --render-only",
    "social:youtube:render:test": "node scripts/social-youtube-publish.mjs --render-only --duration-test=60 --force-render",
    "social:youtube:validate": "node scripts/social-youtube-publish.mjs --validate-only --skip-render",
    "social:youtube:public": "node scripts/social-youtube-publish.mjs --set-public-video-id=znAIzLRtbAo --privacy=public",
    "social:youtube:verify": "node scripts/verify-youtube-playback.mjs",
    "agent:audit": "node scripts/agent-audit.mjs",
    "agent:audit:write": "node scripts/agent-audit.mjs --write",
    "agent:route": "node scripts/agent-routing-report.mjs",
    "agent:route:write": "node scripts/agent-routing-report.mjs --write",
    "agent:jobs:validate": "node scripts/agent-job-validator.mjs",
    "agent:jobs:run": "node scripts/agent-job-runner.mjs",
    "guardian:risk": "node scripts/guardian-risk-summary.mjs",
    "guardian:risk:write": "node scripts/guardian-risk-summary.mjs --write",
    "designer:visual:check": "node scripts/designer-visual-quality-check.mjs",
    "agents:background": "node scripts/agent-background-cycle.mjs",
    "agents:background:deep": "node scripts/agent-background-cycle.mjs --deep",
    "repository:monitor": "node scripts/repository-monitor.mjs",
    "repository:monitor:write": "node scripts/repository-monitor.mjs --write",
    "repository:monitor:strict": "node scripts/repository-monitor.mjs --strict",
    "repository:monitor:strict-warnings": "node scripts/repository-monitor.mjs --strict-warnings",
    "master:gate": "node scripts/master-controller-gate.mjs",
    "tasks:gate": "node scripts/superagent-task-gate.mjs",
    "quality:web": "npm run lint && npm run test -- --run && npm run build",
    "quality:desktop": "npm run desktop:test:logic && npm run desktop:test:e2e",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "drizzle-kit generate",
    "deploy": "vite build && npx wrangler deploy",
    "backup:r2": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/backup-r2.ps1",
    "backup:r2:task": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/register-r2-backup-task.ps1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/lib-storage": "^3.1037.0",
    "@neondatabase/serverless": "^1.0.2",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.1",
    "lenis": "^1.3.21",
    "lucide-react": "^1.11.0",
    "music-metadata": "^11.12.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "drizzle-kit": "^0.31.8",
    "electron": "^41.3.0",
    "electron-builder": "^26.9.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.3.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "wrangler": "^3.107.0"
  },
  "build": {
    "appId": "de.airdox.flightdeck",
    "productName": "AIRDOX Flight Deck",
    "directories": {
      "output": "release"
    },
    "toolsets": {
      "winCodeSign": "1.0.0"
    },
    "files": [
      "dist/**/*",
      "desktop/**/*",
      "src/desktop/lib/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ],
      "artifactName": "AIRDOX-Flight-Deck-${version}.${ext}"
    }
  }
}
