{
  "name": "airdox-web",
  "private": true,
  "version": "0.1.27",
  "main": "desktop/main/index.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "desktop:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/desktop-dev.ps1",
    "desktop:start": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Remove-Item Env:ELECTRON_RUN_AS_NODE -ErrorAction SilentlyContinue; electron .\"",
    "desktop:dist": "npm version patch --no-git-tag-version && npm run build && electron-builder --win portable",
    "desktop:dist:setup": "npm version patch --no-git-tag-version && npm run build && electron-builder --win nsis",
    "desktop:dist:minor": "npm version minor --no-git-tag-version && npm run build && electron-builder --win portable",
    "desktop:dist:major": "npm version major --no-git-tag-version && npm run build && electron-builder --win portable",
    "desktop:dist:setup:minor": "npm version minor --no-git-tag-version && npm run build && electron-builder --win nsis",
    "desktop:dist:setup:major": "npm version major --no-git-tag-version && npm run build && electron-builder --win nsis",
    "desktop:installer": "electron-builder --prepackaged release/win-unpacked --win nsis",
    "desktop:test": "vitest run src/desktop/__tests__",
    "desktop:test:logic": "vitest run src/desktop/lib/__tests__ src/desktop/__tests__",
    "desktop:test:e2e": "npm run build && playwright test e2e/desktop-flightdeck.spec.js e2e/flightdeck-quality.spec.js e2e/flightdeck-assistant.spec.js",
    "desktop:test:proof": "node scratch/capture-analytics-filter-proof.mjs",
    "desktop:test:all": "npm run desktop:test:logic && npm run desktop:test:e2e",
    "tracklist:auto": "node scripts/generate-mixcloud-tracklists.mjs",
    "tracklist:watch": "node scripts/generate-mixcloud-tracklists.mjs --watch --mode cue",
    "tracklist:normalize": "node scripts/normalize-tracklist.mjs",
    "brand:epk": "node scripts/build-airdox-epk.mjs",
    "brand:epk:pdf": "node scripts/build-airdox-epk.mjs --pdf",
    "brand:assets": "node scripts/brand-asset-generator.mjs",
    "brand:assets:strict": "node scripts/brand-asset-generator.mjs --strict",
    "brand:assets:validate": "node scripts/brand-asset-generator.mjs --validate-only --strict",
    "brand:lettering:lab": "node scripts/airdox-lettering-lab.mjs",
    "remotion:airdox:studio": "remotion studio remotion/airdox-reels/src/index.jsx",
    "remotion:airdox:still": "remotion still remotion/airdox-reels/src/index.jsx AIRDOX-Reel-Peak --frame=90 --scale=0.25 --props=remotion/airdox-reels/props/no-audio.json remotion/airdox-reels/out/airdox-reel-peak-preview.png",
    "remotion:airdox:letterhack": "remotion still remotion/airdox-reels/src/index.jsx AIRDOX-Letterhack --frame=96 --scale=0.25 --props=remotion/airdox-reels/props/no-audio.json remotion/airdox-reels/out/airdox-letterhack-preview.png",
    "remotion:airdox:strobe:assets": "node scripts/extract-airdox-separated-letter-assets.mjs",
    "remotion:airdox:strobe:assets:photoshop": "node scripts/run-photoshop-airdox-separated-letter-masks.mjs",
    "remotion:airdox:strobe:assets:sharp": "node scripts/extract-airdox-separated-letter-assets.mjs",
    "remotion:airdox:strobe:still": "npm run remotion:airdox:strobe:assets && remotion still remotion/airdox-reels/src/index.jsx AIRDOX-Letter-Strobe-Proof --frame=18 --scale=0.25 remotion/airdox-reels/out/airdox-letter-strobe-proof.png",
    "remotion:airdox:strobe:render": "npm run remotion:airdox:strobe:assets && remotion render remotion/airdox-reels/src/index.jsx AIRDOX-Letter-Strobe-Proof remotion/airdox-reels/out/airdox-letter-strobe-proof.mp4",
    "remotion:airdox:render": "remotion render remotion/airdox-reels/src/index.jsx AIRDOX-Reel-Peak remotion/airdox-reels/out/airdox-reel-peak.mp4",
    "manni:reels:generate": "node scripts/manni-reel-factory.mjs",
    "mentor:currency": "node scripts/mentor-agent-currency.mjs",
    "mentor:currency:write": "node scripts/mentor-agent-currency.mjs --write",
    "mentor:education": "node scripts/mentor-agent-education.mjs",
    "mentor:education:write": "node scripts/mentor-agent-education.mjs --write",
    "audience:intelligence": "node scripts/audience-intelligence-agent.mjs",
    "audience:intelligence:write": "node scripts/audience-intelligence-agent.mjs --write",
    "analytics:mega": "node scripts/build-mega-analytics-pack.mjs",
    "website:profitability": "node scripts/website-profitability-report.mjs",
    "website:profitability:write": "node scripts/website-profitability-report.mjs",
    "designer:portfolio": "node scripts/designer-portfolio-generator.mjs",
    "social:auto": "node scripts/social-auto-publisher.mjs",
    "social:auto:dry": "node scripts/social-auto-publisher.mjs --skip-render",
    "social:ledger": "node scripts/social-post-ledger.mjs",
    "social:ledger:write": "node scripts/social-post-ledger.mjs --write",
    "social:meta:check": "node scripts/social-meta-publish.mjs --check",
    "social:meta:oauth:init": "node scripts/social-meta-oauth-init.mjs",
    "social:meta:publish": "node scripts/social-meta-publish.mjs",
    "social:run": "npm run social:auto && npm run social:youtube:render:test && npm run social:youtube:publish -- --privacy=unlisted",
    "social:youtube:oauth:init": "node scripts/social-youtube-oauth-init.mjs",
    "social:tiktok:oauth:init": "node scripts/social-tiktok-oauth-init.mjs",
    "social:tiktok:check": "node scripts/social-tiktok-check.mjs",
    "social:tiktok:check:init": "node scripts/social-tiktok-check.mjs --init-only",
    "social:tiktok:upload:inbox": "node scripts/social-tiktok-upload-inbox.mjs",
    "social:youtube:publish": "node scripts/social-youtube-publish.mjs",
    "social:youtube:audit": "node scripts/youtube-publish-audit.mjs",
    "social:youtube:publish:short": "node scripts/social-youtube-publish.mjs --mode=short",
    "social:youtube:dry": "node scripts/social-youtube-publish.mjs --dry-run",
    "social:youtube:render": "node scripts/social-youtube-publish.mjs --render-only",
    "social:youtube:render:test": "node scripts/social-youtube-publish.mjs --render-only --duration-test=60 --force-render",
    "social:youtube:validate": "node scripts/social-youtube-publish.mjs --validate-only --skip-render",
    "social:youtube:public": "node scripts/social-youtube-publish.mjs --set-public-video-id=znAIzLRtbAo --privacy=public",
    "social:youtube:verify": "node scripts/verify-youtube-playback.mjs",
    "agent:audit": "node scripts/agent-audit.mjs",
    "agent:audit:write": "node scripts/agent-audit.mjs --write",
    "agent:route": "node scripts/agent-routing-report.mjs",
    "agent:route:write": "node scripts/agent-routing-report.mjs --write",
    "agent:jobs:validate": "node scripts/agent-job-validator.mjs",
    "agent:jobs:run": "node scripts/agent-job-runner.mjs",
    "refactor:website:opportunities": "node scripts/refactor-website-opportunities.mjs",
    "agent:dependencies:write": "node scripts/agent-dependency-radar.mjs",
    "agent:quality-chain:write": "node scripts/agent-quality-chain.mjs",
    "agent:notebooklm:brief": "node scripts/agent-notebooklm-brief.mjs",
    "agent:system:health": "node scripts/agent-system-health.mjs --write",
    "agent:system:health:strict": "node scripts/agent-system-health.mjs --write --strict",
    "guardian:risk": "node scripts/guardian-risk-summary.mjs",
    "guardian:risk:write": "node scripts/guardian-risk-summary.mjs --write",
    "designer:visual:check": "node scripts/designer-visual-quality-check.mjs",
    "agents:background": "node scripts/agent-background-cycle.mjs",
    "agents:background:deep": "node scripts/agent-background-cycle.mjs --deep",
    "agents:background:task": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/register-agent-background-task.ps1",
    "repository:monitor": "node scripts/repository-monitor.mjs",
    "repository:monitor:write": "node scripts/repository-monitor.mjs --write",
    "repository:monitor:strict": "node scripts/repository-monitor.mjs --strict",
    "repository:monitor:strict-warnings": "node scripts/repository-monitor.mjs --strict-warnings",
    "reports:localize:de": "node scripts/localize-agent-reports.mjs",
    "master:gate": "node scripts/master-controller-gate.mjs",
    "tasks:gate": "node scripts/superagent-task-gate.mjs",
    "quality:web": "npm run lint && npm run test -- --run && npm run build",
    "quality:desktop": "npm run desktop:test:logic && npm run desktop:test:e2e",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "drizzle-kit generate",
    "deploy": "vite build && npx wrangler deploy",
    "backup:r2": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/backup-r2.ps1",
    "backup:r2:task": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/register-r2-backup-task.ps1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/lib-storage": "^3.1037.0",
    "@neondatabase/serverless": "^1.0.2",
    "dotenv": "^17.4.2",
    "json5": "^2.2.3",
    "lenis": "^1.3.21",
    "lucide-react": "^1.11.0",
    "music-metadata": "^11.12.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@remotion/cli": "^4.0.471",
    "@remotion/media-utils": "^4.0.471",
    "@remotion/zod-types": "^4.0.471",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^41.3.0",
    "electron-builder": "^26.9.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.3.0",
    "remotion": "^4.0.471",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "wrangler": "^3.107.0",
    "zod": "^4.3.6"
  },
  "build": {
    "appId": "de.airdox.flightdeck",
    "productName": "AIRDOX Flight Deck",
    "directories": {
      "output": "release"
    },
    "toolsets": {
      "winCodeSign": "1.0.0"
    },
    "files": [
      "dist/**/*",
      "desktop/**/*",
      "src/desktop/lib/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ],
      "artifactName": "AIRDOX-Flight-Deck-${version}.${ext}"
    }
  }
}
