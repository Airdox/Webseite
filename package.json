{
  "name": "airdox-web",
  "private": true,
  "version": "0.1.2",
  "main": "desktop/main/index.mjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "desktop:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/desktop-dev.ps1",
    "desktop:start": "electron .",
    "desktop:dist": "npm run build && electron-builder --win portable",
    "desktop:test": "vitest run src/desktop/__tests__",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "drizzle-kit generate",
    "deploy": "vite build && npx wrangler deploy"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/lib-storage": "^3.1037.0",
    "@neondatabase/serverless": "^1.0.2",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.1",
    "lenis": "^1.3.21",
    "lucide-react": "^1.11.0",
    "music-metadata": "^11.12.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "drizzle-kit": "^0.31.8",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.3.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "wrangler": "^3.107.0"
  },
  "build": {
    "appId": "de.airdox.flightdeck",
    "productName": "AIRDOX Flight Deck",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "desktop/**/*",
      "src/desktop/lib/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "AIRDOX-Flight-Deck-${version}.${ext}"
    }
  }
}
