{
  "name": "airdox-web",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:netlify": "netlify dev",
    "build": "vite build",
    "build:site": "vite build && node scripts/postbuild-trim-audio.js",
    "deploy:audio": "node scripts/deploy-audio.js",
    "lint": "eslint .",
    "preview": "pnpm run build && wrangler dev",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "netlify dev:exec drizzle-kit migrate",
    "db:studio": "netlify dev:exec drizzle-kit studio",
    "deploy": "pnpm run build && wrangler deploy"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@neondatabase/serverless": "^1.0.2",
    "@netlify/blobs": "^10.4.4",
    "@netlify/neon": "^0.1.0",
    "drizzle-orm": "^0.45.1",
    "ffmpeg-static": "^5.3.0",
    "lenis": "^1.3.21",
    "megajs": "^1.3.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@cloudflare/vite-plugin": "^1.31.2",
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.3.0",
    "netlify-cli": "^23.14.0",
    "vite": "^6.4.2",
    "vitest": "^4.0.16",
    "wrangler": "^4.81.1"
  }
