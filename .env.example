# Audio-Konfiguration
VITE_AUDIO_BASE=https://sets.airdox.info/
VITE_AUDIO_API_BASE=
AUDIO_DIR=public/sets

# Cloudflare R2 (Wird für die Migration benötigt)
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Serverless / DB (Cloudflare Workers + Neon)
DATABASE_URL=
NEON_DATABASE_URL=

# CAPTCHA (Cloudflare Turnstile)
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Optional: auf "false" setzen, um CAPTCHA fuer Registrierung zu deaktivieren
REQUIRE_CAPTCHA=true

# Social Publishing - YouTube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Social Publishing - Instagram/Facebook
META_GRAPH_VERSION=v24.0
META_APP_ID=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Social Publishing - TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REFRESH_TOKEN=
