{
  "version": 1,
  "controller": "Master Controller",
  "allowedAgents": [
    "Master Controller",
    "Webbie",
    "Winnie",
    "Guardian",
    "Manni",
    "Designer",
    "Mentor",
    "Refactor",
    "Repository"
  ],
  "jobs": [
    {
      "id": "repository-hygiene-monitor",
      "title": "Repository hygiene monitor",
      "owner": "Repository",
      "execution": "script",
      "script": "repository:monitor:write",
      "scriptArgs": [],
      "trigger": {
        "events": [
          "scheduled_background",
          "manual_background",
          "pr_review"
        ],
        "statuses": [
          "standard",
          "deep"
        ]
      },
      "changeClass": "non_gravierend",
      "requiresMasterApproval": false,
      "enabled": true,
      "outputs": [
        "docs/agent-system/latest-repository-monitor.json",
        "docs/agent-system/latest-repository-monitor.md"
      ]
    },
    {
      "id": "agent-audit-cycle",
      "title": "Cross-agent quality audit",
      "owner": "Guardian",
      "execution": "script",
      "script": "agent:audit:write",
      "scriptArgs": [],
      "trigger": {
        "events": [
          "scheduled_background",
          "manual_background",
          "pr_review"
        ],
        "statuses": [
          "standard",
          "deep"
        ]
      },
      "changeClass": "non_gravierend",
      "requiresMasterApproval": false,
      "enabled": true,
      "outputs": [
        "docs/agent-system/latest-audit.json",
        "docs/agent-system/latest-audit.md"
      ]
    },
    {
      "id": "windows-tool-healthcheck",
      "title": "Windows Tool deep logic check",
      "owner": "Winnie",
      "execution": "script",
      "script": "desktop:test:logic",
      "scriptArgs": [],
      "trigger": {
        "events": [
          "scheduled_background",
          "manual_background",
          "windows_tool_review"
        ],
        "statuses": [
          "deep",
          "morning_review"
        ]
      },
      "changeClass": "non_gravierend",
      "requiresMasterApproval": false,
      "enabled": true,
      "outputs": [
        "terminal:test-output"
      ]
    },
    {
      "id": "website-quality-battery",
      "title": "Website quality battery",
      "owner": "Webbie",
      "execution": "script",
      "script": "quality:web",
      "scriptArgs": [],
      "trigger": {
        "events": [
          "pr_review",
          "release_candidate"
        ],
        "statuses": [
          "ci"
        ]
      },
      "changeClass": "non_gravierend",
      "requiresMasterApproval": false,
      "enabled": true,
      "outputs": [
        "terminal:test-output",
        "dist/*"
      ]
    },
    {
      "id": "promotion-growth-review",
      "title": "Promotion and growth review",
      "owner": "Manni",
      "execution": "manual",
      "manualProtocol": "Run the weekly Manni growth cycle from docs/agent-system/MANNI_GROWTH_PLAYBOOK.md and log winners/losers plus next experiments in docs/agent-system/DECISION_LOG.md.",
      "trigger": {
        "events": [
          "weekly_growth_review"
        ],
        "statuses": [
          "weekly"
        ]
      },
      "changeClass": "non_gravierend",
      "requiresMasterApproval": false,
      "domain": "social_media",
      "outputVisibility": "internal_planning",
      "requiresUserApproval": false,
      "enabled": true,
      "outputs": [
        "docs/agent-system/DECISION_LOG.md"
      ]
    },
    {
      "id": "growth-scenario-selection",
      "title": "Select growth scenario and test matrix",
      "owner": "Manni",
      "execution": "manual",
      "manualProtocol": "Pick scenario A/B/C/D from MANNI_GROWTH_PLAYBOOK.md based on current KPIs and define the weekly test matrix.",
      "trigger": {
        "events": [
          "weekly_growth_review",
          "release_candidate",
          "reach_drop"
        ],
        "statuses": [
          "weekly",
          "planning",
          "incident"
        ]
      },
      "changeClass": "non_gravierend",
      "requiresMasterApproval": false,
      "domain": "social_media",
      "outputVisibility": "internal_planning",
      "requiresUserApproval": false,
      "enabled": true,
      "outputs": [
        "docs/agent-system/DECISION_LOG.md",
        "docs/agent-system/MANNI_GROWTH_PLAYBOOK.md"
      ]
    },
    {
      "id": "design-creative-pack",
      "title": "Create weekly social creative pack",
      "owner": "Designer",
      "execution": "manual",
      "manualProtocol": "Create and review hooks, visual style directions, frame scripts and thumbnail concepts for Manni's weekly queue.",
      "trigger": {
        "events": [
          "weekly_growth_review",
          "release_candidate"
        ],
        "statuses": [
          "weekly",
          "planning"
        ]
      },
      "changeClass": "non_gravierend",
      "requiresMasterApproval": false,
      "domain": "social_media",
      "outputVisibility": "internal_planning",
      "requiresUserApproval": false,
      "enabled": true,
      "outputs": [
        "docs/agent-system/manni-reel-weekly-plan.md",
        "docs/agent-system/DECISION_LOG.md"
      ]
    },
    {
      "id": "designer-pdf-draft-build",
      "title": "Build AIRDOX branded PDF draft pack",
      "owner": "Designer",
      "execution": "script",
      "script": "brand:epk",
      "scriptArgs": [],
      "trigger": {
        "events": [
          "weekly_growth_review",
          "scheduled_background",
          "release_candidate"
        ],
        "statuses": [
          "weekly",
          "planning",
          "deep"
        ]
      },
      "changeClass": "non_gravierend",
      "requiresMasterApproval": false,
      "domain": "brand_assets",
      "outputVisibility": "internal_planning",
      "requiresUserApproval": false,
      "enabled": true,
      "outputs": [
        "public/epk/airdox-epk.html"
      ]
    },
    {
      "id": "designer-pdf-live-build",
      "title": "Build AIRDOX branded live PDF",
      "owner": "Designer",
      "execution": "script",
      "script": "brand:epk:pdf",
      "scriptArgs": [],
      "trigger": {
        "events": [
          "manual_publish_request",
          "release_candidate"
        ],
        "statuses": [
          "pending_user_ok",
          "ci"
        ]
      },
      "changeClass": "non_gravierend",
      "requiresMasterApproval": false,
      "domain": "brand_assets",
      "outputVisibility": "external_live",
      "requiresUserApproval": true,
      "enabled": true,
      "outputs": [
        "public/epk/airdox-epk.pdf"
      ]
    },
    {
      "id": "manni-reel-factory",
      "title": "Generate reel queue and weekly social plan",
      "owner": "Manni",
      "execution": "script",
      "script": "manni:reels:generate",
      "scriptArgs": [],
      "trigger": {
        "events": [
          "scheduled_background",
          "weekly_growth_review",
          "manual_background",
          "release_candidate"
        ],
        "statuses": [
          "weekly",
          "deep",
          "standard",
          "planning"
        ]
      },
      "changeClass": "non_gravierend",
      "requiresMasterApproval": false,
      "domain": "social_media",
      "outputVisibility": "internal_planning",
      "requiresUserApproval": false,
      "enabled": true,
      "outputs": [
        "docs/agent-system/manni-reel-queue.json",
        "docs/agent-system/manni-reel-weekly-plan.md"
      ]
    },
    {
      "id": "growth-winner-amplification",
      "title": "Amplify proven winner assets",
      "owner": "Manni",
      "execution": "manual",
      "manualProtocol": "Escalate only top-performing organic assets into paid amplification and document budget/creative rationale.",
      "trigger": {
        "events": [
          "winner_detected",
          "release_candidate"
        ],
        "statuses": [
          "scale",
          "ci"
        ]
      },
      "changeClass": "non_gravierend",
      "requiresMasterApproval": false,
      "domain": "social_media",
      "outputVisibility": "external_live",
      "requiresUserApproval": true,
      "enabled": true,
      "outputs": [
        "docs/agent-system/DECISION_LOG.md"
      ]
    },
    {
      "id": "social-live-publish-gate",
      "title": "Personal approval gate before live social posting",
      "owner": "Manni",
      "execution": "manual",
      "manualProtocol": "Before any external posting or paid activation goes live, get explicit personal user OK and log it in DECISION_LOG.",
      "trigger": {
        "events": [
          "winner_detected",
          "release_candidate",
          "manual_publish_request"
        ],
        "statuses": [
          "scale",
          "ci",
          "pending_user_ok"
        ]
      },
      "changeClass": "non_gravierend",
      "requiresMasterApproval": false,
      "domain": "social_media",
      "outputVisibility": "external_live",
      "requiresUserApproval": true,
      "enabled": true,
      "outputs": [
        "docs/agent-system/DECISION_LOG.md"
      ]
    },
    {
      "id": "learning-gap-update",
      "title": "Learning gap and runbook update",
      "owner": "Mentor",
      "execution": "manual",
      "manualProtocol": "Update wiki learning loops after repeated failures or major incidents.",
      "trigger": {
        "events": [
          "incident_review",
          "monthly_learning_review"
        ],
        "statuses": [
          "needs_learning",
          "monthly"
        ]
      },
      "changeClass": "non_gravierend",
      "requiresMasterApproval": false,
      "enabled": true,
      "outputs": [
        "airdoX_wiki/wiki/local-11-feedback-loops.md",
        "airdoX_wiki/wiki/log.md"
      ]
    },
    {
      "id": "cross-module-refactor-plan",
      "title": "Cross-module refactor plan",
      "owner": "Refactor",
      "execution": "manual",
      "manualProtocol": "Prepare an impact analysis and phased plan before any broad restructuring.",
      "trigger": {
        "events": [
          "architecture_drift",
          "performance_degradation"
        ],
        "statuses": [
          "high_complexity",
          "high_latency"
        ]
      },
      "changeClass": "gravierend",
      "requiresMasterApproval": true,
      "enabled": true,
      "outputs": [
        "docs/agent-system/DECISION_LOG.md"
      ]
    },
    {
      "id": "release-branch-strategy-change",
      "title": "Release branching strategy change",
      "owner": "Master Controller",
      "execution": "manual",
      "manualProtocol": "Approve or reject branch strategy changes after risk and compatibility review.",
      "trigger": {
        "events": [
          "release_policy_change"
        ],
        "statuses": [
          "proposal"
        ]
      },
      "changeClass": "gravierend",
      "requiresMasterApproval": true,
      "enabled": true,
      "outputs": [
        "docs/agent-system/DECISION_LOG.md",
        "docs/agent-system/REPOSITORY_GOVERNANCE.md"
      ]
    }
  ]
}
